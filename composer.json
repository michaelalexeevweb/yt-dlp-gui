{
    "name": "michaelalexeevweb/yt-dlp-gui",
    "description": "Desktop GUI wrapper around yt-dlp on PHP with Boson runtime.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "ext-ffi": "*",
        "boson-php/runtime": "^0.19.5"
    },
    "require-dev": {
        "boson-php/compiler": "^0.19",
        "phpstan/phpstan": "^2.1",
        "symfony/console": "^7.3"
    },
    "autoload": {
        "psr-4": {
            "YtDlpGui\\": "src/"
        }
    },
    "scripts": {
        "phpstan": "phpstan analyse",
        "console": "php bin/console",
        "build-release": "php bin/console app:build:release",
        "check": [
            "@phpstan"
        ]
    },
    "authors": [
        {
            "name": "Michael Alexeev",
            "email": "michael.alexeev.web@gmail.com"
        }
    ],
    "keywords": [
        "yt-dlp",
        "php",
        "gui",
        "desktop",
        "downloader",
        "boson"
    ],
    "minimum-stability": "stable",
    "prefer-stable": true
}
