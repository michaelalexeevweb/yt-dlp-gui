#!/usr/bin/env php
<?php

declare(strict_types=1);

$bootstrapLogPath = rtrim(sys_get_temp_dir(), '/\\') . DIRECTORY_SEPARATOR . 'ytdlpgui_startup_bootstrap.log';

register_shutdown_function(static function () use ($bootstrapLogPath): void {
    $lastError = error_get_last();
    if (!is_array($lastError)) {
        return;
    }

    $fatalTypes = [E_ERROR, E_PARSE, E_CORE_ERROR, E_COMPILE_ERROR, E_USER_ERROR];
    if (!in_array($lastError['type'], $fatalTypes, true)) {
        return;
    }

    @file_put_contents(
        $bootstrapLogPath,
        sprintf(
            "[%s] fatal startup error: %s in %s:%d\n",
            date(DATE_ATOM),
            $lastError['message'],
            $lastError['file'],
            $lastError['line'],
        ),
        FILE_APPEND,
    );
});

if (PHP_OS_FAMILY === 'Windows' && class_exists(Phar::class, false)) {
    $running = Phar::running(false);
    $normalizedRunning = str_replace('/', '\\', $running);
    $isUncPath = str_starts_with($normalizedRunning, '\\\\');

    $copyTree = static function (string $from, string $to) use (&$copyTree): bool {
        if (!is_dir($from)) {
            return false;
        }

        if (!is_dir($to) && !mkdir($to, 0775, true) && !is_dir($to)) {
            return false;
        }

        $entries = scandir($from);
        if (!is_array($entries)) {
            return false;
        }

        foreach ($entries as $entry) {
            if ($entry === '.' || $entry === '..') {
                continue;
            }

            $sourcePath = $from . DIRECTORY_SEPARATOR . $entry;
            $targetPath = $to . DIRECTORY_SEPARATOR . $entry;

            if (is_dir($sourcePath)) {
                if (!$copyTree($sourcePath, $targetPath)) {
                    return false;
                }

                continue;
            }

            if (!copy($sourcePath, $targetPath)) {
                return false;
            }
        }

        return true;
    };

    $removeTree = static function (string $path) use (&$removeTree): bool {
        if (!is_dir($path)) {
            return true;
        }

        $entries = scandir($path);
        if (!is_array($entries)) {
            return false;
        }

        foreach ($entries as $entry) {
            if ($entry === '.' || $entry === '..') {
                continue;
            }

            $entryPath = $path . DIRECTORY_SEPARATOR . $entry;
            if (is_dir($entryPath)) {
                if (!$removeTree($entryPath)) {
                    return false;
                }

                continue;
            }

            if (!@unlink($entryPath)) {
                return false;
            }
        }

        return @rmdir($path);
    };

    @file_put_contents(
        $bootstrapLogPath,
        sprintf(
            "[%s] bootstrap: running=%s unc=%s\n",
            date(DATE_ATOM),
            $normalizedRunning,
            $isUncPath ? 'yes' : 'no',
        ),
        FILE_APPEND,
    );

    if (
        $normalizedRunning !== ''
        && $isUncPath
    ) {
        $localAppData = getenv('LOCALAPPDATA');

        if (is_string($localAppData) && $localAppData !== '') {
            $sourceDir = dirname($normalizedRunning);
            $artifactFingerprint = sprintf(
                '%s|%s|%s',
                $normalizedRunning,
                @filesize($normalizedRunning) ?: 0,
                @filemtime($normalizedRunning) ?: 0,
            );
            $runKey = substr(sha1($artifactFingerprint), 0, 12);
            $targetDir = rtrim($localAppData, '/\\') . '\\YtDlpGui\\run\\' . $runKey;
            $isDesktopBuild = is_file($sourceDir . DIRECTORY_SEPARATOR . '.desktop-build');
            $requiredFiles = [basename($normalizedRunning), 'libboson-windows-x86_64.dll'];
            if (!$isDesktopBuild) {
                $requiredFiles = [
                    ...$requiredFiles,
                    'vcruntime140.dll',
                    'vcruntime140_1.dll',
                    'msvcp140.dll',
                    'msvcp140_atomic_wait.dll',
                ];
            }

            $hasRequiredFiles = static function (string $baseDir) use ($requiredFiles): bool {
                clearstatcache();
                foreach ($requiredFiles as $requiredFile) {
                    $requiredPath = $baseDir . DIRECTORY_SEPARATOR . $requiredFile;
                    if (!is_file($requiredPath) || !is_readable($requiredPath)) {
                        return false;
                    }
                }

                return true;
            };

            $missingRequiredFiles = static function (string $baseDir) use ($requiredFiles): array {
                clearstatcache();
                $missing = [];
                foreach ($requiredFiles as $requiredFile) {
                    $requiredPath = $baseDir . DIRECTORY_SEPARATOR . $requiredFile;
                    if (!is_file($requiredPath) || !is_readable($requiredPath)) {
                        $missing[] = $requiredFile;
                    }
                }
                return $missing;
            };

            $normalizedTargetDir = str_replace('/', '\\', $targetDir);
            $alreadyLocal = str_starts_with(
                strtolower($normalizedRunning),
                strtolower($normalizedTargetDir . '\\'),
            );

            if ($alreadyLocal) {
                // Already running from local cache path.
            } else {
                if (is_dir($targetDir) && !$hasRequiredFiles($targetDir)) {
                    $removeTree($targetDir);
                }

                if (!is_dir($targetDir)) {
                    $stagingDir = $targetDir . '.tmp.' . (string)getmypid();
                    $removeTree($stagingDir);

                    $copied = $copyTree($sourceDir, $stagingDir);
                    if ($copied) {
                        if (!@rename($stagingDir, $targetDir)) {
                            $removeTree($stagingDir);
                            $copied = false;
                        }
                    } else {
                        $removeTree($stagingDir);
                    }
                } else {
                    $copied = true;
                }

                $targetExe = $targetDir . '\\' . basename($normalizedRunning);
                if ($copied && $hasRequiredFiles($targetDir) && is_file($targetExe)) {
                    @file_put_contents(
                        $bootstrapLogPath,
                        sprintf(
                            "[%s] bootstrap: launching local exe %s\n",
                            date(DATE_ATOM),
                            $targetExe,
                        ),
                        FILE_APPEND,
                    );

                    $launchCommand = sprintf(
                        'cmd /c start "" "%s"',
                        str_replace('"', '""', $targetExe),
                    );
                    @exec($launchCommand);
                    exit(0);
                }

                $missingInTarget = $missingRequiredFiles($targetDir);
                $missingList = implode(', ', $missingInTarget);
                @file_put_contents(
                    $bootstrapLogPath,
                    sprintf(
                        "[%s] bootstrap: cannot prepare complete app bundle. source=%s target=%s copied=%s missing=%s\n",
                        date(DATE_ATOM),
                        $sourceDir,
                        $targetDir,
                        $copied ? 'yes' : 'no',
                        $missingList !== '' ? $missingList : 'none',
                    ),
                    FILE_APPEND,
                );

                $bootstrapErrorMessage = $isDesktopBuild
                    ? sprintf(
                        "YtDlpGui cannot start: incomplete desktop app bundle.\n\nMissing files in the release folder:\n  %s\n\nMake sure you extracted the full ZIP archive.\nDesktop build still requires YtDlpGui.exe and libboson-windows-x86_64.dll in same folder.\n\nLog: %s",
                        $missingList !== '' ? str_replace(', ', "\n  ", $missingList) : '(unknown)',
                        $bootstrapLogPath,
                    )
                    : sprintf(
                        "YtDlpGui cannot start: incomplete app bundle.\n\nMissing files in the release folder:\n  %s\n\nMake sure you extracted the full ZIP archive.\nIf VC++ DLLs are listed above, install:\nhttps://aka.ms/vs/17/release/vc_redist.x64.exe\n\nLog: %s",
                        $missingList !== '' ? str_replace(', ', "\n  ", $missingList) : '(unknown)',
                        $bootstrapLogPath,
                    );

                $psScript = sprintf(
                    "Add-Type -AssemblyName PresentationFramework; [System.Windows.MessageBox]::Show('%s', 'YtDlpGui startup error') | Out-Null",
                    str_replace("'", "''", $bootstrapErrorMessage),
                );
                @exec(sprintf('powershell -NoProfile -ExecutionPolicy Bypass -Command %s', escapeshellarg($psScript)));

                fwrite(STDERR, $bootstrapErrorMessage . "\n");
                exit(1);
            }
        }
    }
}

if (PHP_OS_FAMILY === 'Windows') {
    $showWindowsStartupError = static function (string $message): void {
        $psScript = sprintf(
            "Add-Type -AssemblyName PresentationFramework; [System.Windows.MessageBox]::Show('%s', 'YtDlpGui startup error') | Out-Null",
            str_replace("'", "''", $message),
        );
        $command = sprintf(
            'powershell -NoProfile -ExecutionPolicy Bypass -Command %s',
            escapeshellarg($psScript),
        );

        @exec($command);
    };

    $requiredRuntimeDlls = ['vcruntime140.dll', 'vcruntime140_1.dll', 'msvcp140.dll', 'msvcp140_atomic_wait.dll'];
    $probeDirectories = [];

    $running = class_exists(Phar::class, false) ? Phar::running(false) : '';
    if ($running !== '') {
        $probeDirectories[] = dirname($running);
    }

    $windowsDir = getenv('WINDIR');
    if (is_string($windowsDir) && $windowsDir !== '') {
        $probeDirectories[] = rtrim($windowsDir, '/\\') . '\\System32';
        $probeDirectories[] = rtrim($windowsDir, '/\\') . '\\SysWOW64';
    }

    // Note: PATH is intentionally excluded. The native Windows DLL loader resolves
    // libboson's dependencies from the DLL's own directory and System32 — not from
    // arbitrary PATH entries. Accepting PATH here would produce false negatives
    // (startup check passes but libboson still fails to load at runtime).

    $probeDirectories = array_values(array_unique($probeDirectories));

    $missingRuntimeDlls = [];
    foreach ($requiredRuntimeDlls as $runtimeDll) {
        $found = false;

        foreach ($probeDirectories as $probeDirectory) {
            $candidate = rtrim($probeDirectory, '/\\') . DIRECTORY_SEPARATOR . $runtimeDll;
            if (is_file($candidate) && is_readable($candidate)) {
                $found = true;
                break;
            }
        }

        if (!$found) {
            $missingRuntimeDlls[] = $runtimeDll;
        }
    }

    if ($missingRuntimeDlls !== []) {
        $runtimeList = implode(', ', $missingRuntimeDlls);
        $errorMessage = sprintf(
            "YtDlpGui cannot start because required runtime DLLs are missing: %s\n\nThese files must be present either:\n  - next to YtDlpGui.exe (bundled), or\n  - in C:\\Windows\\System32 (system-wide install)\n\nOption 1: re-download a complete build from the maintainer.\nOption 2: install Microsoft Visual C++ Redistributable 2015-2022 (x64):\nhttps://aka.ms/vs/17/release/vc_redist.x64.exe",
            $runtimeList,
        );

        $bootstrapLogPath = rtrim(sys_get_temp_dir(), '/\\') . DIRECTORY_SEPARATOR . 'ytdlpgui_startup_bootstrap.log';
        @file_put_contents(
            $bootstrapLogPath,
            sprintf(
                "[%s] bootstrap: missing VC++ runtime DLLs: %s\n",
                date(DATE_ATOM),
                $runtimeList,
            ),
            FILE_APPEND,
        );

        fwrite(STDERR, $errorMessage . "\n");
        $showWindowsStartupError($errorMessage);
        exit(1);
    }
}

require __DIR__ . '/../vendor/autoload.php';

use Boson\Application as BosonApplication;
use Boson\ApplicationCreateInfo;
use Boson\WebView\WebViewCreateInfo;
use Boson\Window\WindowCreateInfo;
use YtDlpGui\Download\DownloadsDirectoryResolver;
use YtDlpGui\Download\YtDlpJobService;
use YtDlpGui\Ui\DirectoryChooser;

set_exception_handler(static function (\Throwable $e): void {
    $logPath = sprintf('%s/%s', rtrim(sys_get_temp_dir(), '/\\'), 'ytdlpgui_startup_error.log');
    $logChunk = sprintf(
        "[%s] %s\n%s\n\n",
        date(DATE_ATOM),
        $e->getMessage(),
        $e->getTraceAsString(),
    );

    @file_put_contents($logPath, $logChunk, FILE_APPEND);

    if (PHP_OS_FAMILY === 'Windows') {
        $running = Phar::running(false);
        $dllPath = str_replace('/', '\\', dirname($running)) . '\\libboson-windows-x86_64.dll';
        $dllExists = is_file($dllPath) ? 'yes' : 'no';
        $dllReadable = is_readable($dllPath) ? 'yes' : 'no';
        $windowsDir = getenv('WINDIR');
        $system32 = is_string($windowsDir) && $windowsDir !== ''
            ? rtrim($windowsDir, '/\\') . '\\System32'
            : 'C:\\Windows\\System32';
        $vcrt140 = $system32 . '\\vcruntime140.dll';
        $vcrt140_1 = $system32 . '\\vcruntime140_1.dll';
        $msvcp140 = $system32 . '\\msvcp140.dll';
        $programFilesX86 = getenv('ProgramFiles(x86)');
        $webView2Dir = is_string($programFilesX86) && $programFilesX86 !== ''
            ? $programFilesX86 . '\\Microsoft\\EdgeWebView\\Application'
            : '';
        $webView2Present = $webView2Dir !== '' && is_dir($webView2Dir) ? 'yes' : 'no';

        @file_put_contents(
            $logPath,
            sprintf(
                "[%s] diagnostics: running=%s; lib=%s; exists=%s; readable=%s; vcruntime140=%s; vcruntime140_1=%s; msvcp140=%s; webview2=%s\n\n",
                date(DATE_ATOM),
                $running,
                $dllPath,
                $dllExists,
                $dllReadable,
                is_file($vcrt140) ? 'yes' : 'no',
                is_file($vcrt140_1) ? 'yes' : 'no',
                is_file($msvcp140) ? 'yes' : 'no',
                $webView2Present,
            ),
            FILE_APPEND,
        );

        $extraHint = '';
        if (str_contains($e->getMessage(), 'libboson-windows-x86_64.dll')) {
            $extraHint = sprintf(
                "\n\nDiagnostics:\n- lib path: %s\n- exists: %s\n- readable: %s\n- vcruntime140.dll in System32: %s\n- vcruntime140_1.dll in System32: %s\n- msvcp140.dll in System32: %s\n- Edge WebView2 runtime folder: %s\n\nInstall:\n1) Microsoft Edge WebView2 Runtime\n2) Microsoft Visual C++ Redistributable 2015-2022 (x64)",
                $dllPath,
                $dllExists,
                $dllReadable,
                is_file($vcrt140) ? 'yes' : 'no',
                is_file($vcrt140_1) ? 'yes' : 'no',
                is_file($msvcp140) ? 'yes' : 'no',
                $webView2Present,
            );
        }

        $message = sprintf(
            "YtDlpGui failed to start.\n\n%s\n\nLog: %s%s",
            $e->getMessage(),
            $logPath,
            $extraHint,
        );

        $psScript = sprintf(
            "Add-Type -AssemblyName PresentationFramework; [System.Windows.MessageBox]::Show('%s', 'YtDlpGui startup error') | Out-Null",
            str_replace("'", "''", $message),
        );
        $command = sprintf(
            'powershell -NoProfile -ExecutionPolicy Bypass -Command %s',
            escapeshellarg($psScript),
        );

        @exec($command);
        exit(1);
    }

    fwrite(STDERR, sprintf("YtDlpGui startup error: %s\n", $e->getMessage()));
    exit(1);
});

$downloadsDirectory = DownloadsDirectoryResolver::defaultForCurrentUser();

$jobService = new YtDlpJobService(
    downloadsDirectory: $downloadsDirectory,
);

register_shutdown_function(static function () use ($jobService): void {
    $jobService->stopAllActiveJobs();
});

$bosonLibrary = null;
if (PHP_OS_FAMILY === 'Windows' && class_exists(Phar::class, false)) {
    $running = Phar::running(false);
    if ($running !== '') {
        $runDir = str_replace('/', '\\', dirname($running));
        $candidate = $runDir . DIRECTORY_SEPARATOR . 'libboson-windows-x86_64.dll';
        if (is_file($candidate) && is_readable($candidate)) {
            $bosonLibrary = $candidate;
        }

        // Preload VC++ runtime DLLs from the run directory before Boson loads libboson.
        // PHP FFI may use LOAD_LIBRARY_SEARCH_DEFAULT_DIRS when resolving libboson's
        // dependencies, which does not include the DLL's own directory. By explicitly
        // loading the VC++ DLLs into the process first (via kernel32 LoadLibraryA),
        // they are already in the module list when libboson's imports are resolved.
        $vcRuntimeDlls = ['vcruntime140.dll', 'vcruntime140_1.dll', 'msvcp140.dll', 'msvcp140_atomic_wait.dll'];
        $anyVcRuntimePresent = false;
        foreach ($vcRuntimeDlls as $vcDll) {
            if (is_file($runDir . DIRECTORY_SEPARATOR . $vcDll)) {
                $anyVcRuntimePresent = true;
                break;
            }
        }

        if ($anyVcRuntimePresent) {
            try {
                $kernel32 = FFI::cdef('void* __stdcall LoadLibraryA(const char* lpLibFileName);', 'kernel32.dll');
                foreach ($vcRuntimeDlls as $vcDll) {
                    $vcDllPath = $runDir . DIRECTORY_SEPARATOR . $vcDll;
                    if (is_file($vcDllPath) && is_readable($vcDllPath)) {
                        $kernel32->LoadLibraryA($vcDllPath);
                    }
                }
            } catch (\Throwable) {
                // Preloading is best-effort; if kernel32 FFI fails, proceed anyway.
            }
        }
    }
}

$app = new BosonApplication(
    info: new ApplicationCreateInfo(
        name: 'YtDlpGui',
        debug: false,
        library: $bosonLibrary,
        window: new WindowCreateInfo(
            title: 'YtDlpGui',
            width: 1200,
            height: 800,
            webview: new WebViewCreateInfo(
                devTools: false,
            ),
        ),
    ),
);

$app->webview->bindings->bind(
    function: 'startDownload',
    callback: static function (string $url, string $formatId = 'bestvideo*+bestaudio/best', string $downloadDirectory = ''): array {
        $dir = trim($downloadDirectory);
        if ($dir === '' || !is_dir($dir)) {
            $dir = DownloadsDirectoryResolver::defaultForCurrentUser();
        }

        $service = new YtDlpJobService(downloadsDirectory: $dir);
        return $service->start(
            url: $url,
            formatId: $formatId,
        );
    },
);

$app->webview->bindings->bind(
    function: 'pollDownload',
    callback: static function (string $jobId, int $offset) use ($jobService): array {
        return $jobService->status(
            jobId: $jobId,
            offset: $offset,
        );
    },
);

$app->webview->bindings->bind(
    function: 'selectDownloadDirectory',
    callback: static function (): array {
        $chooser = new DirectoryChooser();
        $chosen = $chooser->choose();

        if (!$chosen || !is_dir($chosen)) {
            return [
                'success' => false,
                'directory' => null,
                'message' => 'No directory selected.',
            ];
        }

        return [
            'success' => true,
            'directory' => $chosen,
            'message' => sprintf('Directory selected: %s', basename($chosen)),
        ];
    },
);

$app->webview->bindings->bind(
    function: 'openDownloadsFolder',
    callback: static function (string $directory = '') use ($jobService): array {
        $dir = trim($directory);
        if ($dir === '' || !is_dir($dir)) {
            return $jobService->openDownloadsFolder();
        }

        $command = sprintf('open %s >/dev/null 2>&1', escapeshellarg($dir));
        exec($command);

        return [
            'success' => true,
            'message' => sprintf('Opened %s', basename($dir)),
        ];
    },
);

$app->webview->bindings->bind(
    function: 'checkRuntimeDependencies',
    callback: static function () use ($jobService): array {
        return $jobService->checkRuntimeDependencies();
    },
);

$app->webview->bindings->bind(
    function: 'openInstallCommandInTerminal',
    callback: static function (string $command): array {
        $trimmedCommand = trim($command);
        if ($trimmedCommand === '') {
            return [
                'success' => false,
                'message' => 'Install command is empty.',
            ];
        }

        if (PHP_OS_FAMILY === 'Darwin') {
            $escapedCommand = str_replace(['\\', '"'], ['\\\\', '\\"'], $trimmedCommand);
            $script = sprintf('tell application "Terminal" to activate\ntell application "Terminal" to do script "%s"', $escapedCommand);
            $output = [];
            $exitCode = 0;
            exec(
                command: sprintf('osascript -e %s', escapeshellarg($script)),
                output: $output,
                result_code: $exitCode,
            );

            return [
                'success' => $exitCode === 0,
                'message' => $exitCode === 0
                    ? 'Terminal opened with install command.'
                    : 'Cannot open Terminal automatically. Copy command from the red block and run it manually.',
            ];
        }

        return [
            'success' => false,
            'message' => 'Automatic terminal launcher is currently implemented for macOS only.',
        ];
    },
);

$app->webview->bindings->bind(
    function: 'stopDownload',
    callback: static function (string $jobId) use ($jobService): array {
        return $jobService->stop($jobId);
    },
);

$app->webview->bindings->bind(
    function: 'stopAllDownloads',
    callback: static function () use ($jobService): array {
        $stopped = $jobService->stopAllActiveJobs();

        return [
            'success' => true,
            'message' => sprintf('Stopped %d active job(s).', $stopped),
            'stopped' => $stopped,
        ];
    },
);

$app->webview->bindings->bind(
    function: 'closeApplication',
    callback: static function () use ($app, $jobService): array {
        $jobService->stopAllActiveJobs();
        $app->quit();

        return [
            'success' => true,
            'message' => 'Closing application...',
        ];
    },
);

