    @keyframes progress-stripes { to { background-position: 28px 0; } }
  </style>
</head>
<body>
  <main class="wrap">
    <h1>Yt Dlp Gui</h1>
    <div class="card">
      <form id="download-form">
        <div class="row">
          <div>
            <label for="url">URL</label>
            <input id="url" name="url" type="url" placeholder="https://www.youtube.com/watch?v=..." required>
          </div>
          <div id="format-controls" class="hidden">
            <label for="video-profile-select" style="margin-top: 8px;">Formats</label>
            <select id="video-profile-select" name="video-profile-select"></select>
            <label for="quality-select" style="margin-top: 8px;">Quality</label>
            <select id="quality-select" name="quality-select" size="9"></select>
            <div class="hint">Choose format first, then quality. Default format gives merged video+audio.</div>
          </div>
        </div>
        <div class="actions">
          <button id="choose-folder-button" class="secondary" type="button">Choose folder</button>
          <button id="download-button" type="submit">Download</button>
          <button id="stop-button" class="danger hidden" type="button" disabled>Stop</button>
          <button id="open-folder-button" class="secondary hidden" type="button" disabled>Open in folder</button>
          <span id="spinner" class="spinner" aria-hidden="true"></span>
        </div>
      </form>
      <div id="status" class="status hidden" role="status"></div>
      <div id="dependency-warning" class="status error hidden" role="alert">
        <div id="dependency-warning-text"></div>
        <pre id="dependency-install-command" class="hidden" style="min-height: 0; margin-top: 8px;"></pre>
        <div class="actions" style="margin-top: 8px;">
          <button id="open-install-terminal-button" class="secondary" type="button">Open terminal with install command</button>
        </div>
      </div>
      <div class="actions hidden" id="details-actions" style="margin-top: 12px;">
        <button id="toggle-details-button" class="secondary" type="button">Hide progress and log</button>
      </div>
      <div id="progress-wrap" class="progress-wrap hidden" aria-live="polite">
        <div class="progress-meta">
          <span>Progress</span>
          <span class="progress-meta-right">
            <span id="elapsed-label">00:00</span>
            <span id="progress-label">0%</span>
          </span>
        </div>
        <div class="progress-bar">
          <div id="progress-value" class="progress-value"></div>
        </div>
      </div>
      <pre id="output" class="hidden"></pre>
    </div>
  </main>

  <script>
      const form = document.getElementById('download-form');
      const urlInput = document.getElementById('url');
      const videoProfileSelect = document.getElementById('video-profile-select');
      const qualitySelect = document.getElementById('quality-select');
      const formatControls = document.getElementById('format-controls');
      const openFolderButton = document.getElementById('open-folder-button');
      const stopButton = document.getElementById('stop-button');
      const downloadButton = document.getElementById('download-button');
      const chooseFolderButton = document.getElementById('choose-folder-button');
      const spinner = document.getElementById('spinner');
      const status = document.getElementById('status');
      const output = document.getElementById('output');
      const progressValue = document.getElementById('progress-value');
      const progressLabel = document.getElementById('progress-label');
      const elapsedLabel = document.getElementById('elapsed-label');
      const progressWrap = document.getElementById('progress-wrap');
      const detailsActions = document.getElementById('details-actions');
      const toggleDetailsButton = document.getElementById('toggle-details-button');
      const dependencyWarning = document.getElementById('dependency-warning');
      const dependencyWarningText = document.getElementById('dependency-warning-text');
      const dependencyInstallCommand = document.getElementById('dependency-install-command');
      const openInstallTerminalButton = document.getElementById('open-install-terminal-button');

      let activeJobId = null;
      let activeOffset = 0;
      let pollTimer = null;
      let hasSuccessfulDownload = false;
      let hasDownloadDetails = false;
      let isDetailsExpanded = true;
      let hasConvertingLogNotice = false;
      let lastStageLogged = '';
      let downloadStartedAt = null;
      let selectedDownloadDirectory = null;
      let runtimeReady = true;
      let installCommand = '';
      let isClosingApplication = false;
      let isStoppingDownload = false;
      let profileCache = [
        {
          id: 'mp4-video',
          label: 'MP4 (convert from best quality)',
          qualities: [
            { id: 'auto', label: 'Auto', formatId: 'preset:mp4' },
            { id: '144', label: '144p', formatId: 'preset:mp4:144' },
            { id: '240', label: '240p', formatId: 'preset:mp4:240' },
            { id: '360', label: '360p', formatId: 'preset:mp4:360' },
            { id: '480', label: '480p', formatId: 'preset:mp4:480' },
            { id: '720', label: '720p', formatId: 'preset:mp4:720' },
            { id: '1080', label: '1080p', formatId: 'preset:mp4:1080' },
            { id: '1440', label: '1440p', formatId: 'preset:mp4:1440' },
            { id: '2160', label: '2160p', formatId: 'preset:mp4:2160' },
          ],
        },
        {
          id: 'mp3-audio',
          label: 'MP3 (convert from best audio)',
          qualities: [
            { id: 'auto', label: 'Auto', formatId: 'preset:mp3' },
            { id: '64', label: '64 kbps', formatId: 'preset:mp3:64' },
            { id: '128', label: '128 kbps', formatId: 'preset:mp3:128' },
            { id: '256', label: '256 kbps', formatId: 'preset:mp3:256' },
            { id: '320', label: '320 kbps', formatId: 'preset:mp3:320' },
          ],
        },
      ];

      const setStatus = (text, mode = 'idle') => {
        const normalizedText = String(text).trim();
        status.textContent = normalizedText;
        status.className = 'status';
        status.classList.toggle('hidden', normalizedText.length === 0);

        if (normalizedText.length === 0) {
          return;
        }

        if (mode === 'ok') {
          status.classList.add('ok');
        }
        if (mode === 'error') {
          status.classList.add('error');
        }
      };

      const setProgress = (percent) => {
        const normalized = Math.max(0, Math.min(100, Number(percent) || 0));
        progressValue.style.width = `${normalized}%`;
        progressValue.classList.toggle('completed', normalized >= 100);
        progressValue.classList.remove('stopped');
        progressLabel.textContent = `${normalized.toFixed(1)}%`;
        updateElapsedLabel();
      };

      const markProgressStopped = () => {
        progressValue.classList.remove('completed');
        progressValue.classList.add('stopped');
      };

      const setProgressIfHigher = (percent) => {
        const current = Number.parseFloat(progressLabel.textContent.replace('%', '')) || 0;
        const normalized = Math.max(0, Math.min(100, Number(percent) || 0));
        if (normalized > current) {
          setProgress(normalized);
        }
      };

      const updateElapsedLabel = () => {
        if (!downloadStartedAt) {
          elapsedLabel.textContent = '00:00';
          return;
        }

        const elapsedMs = Math.max(0, Date.now() - downloadStartedAt);
        const totalSeconds = Math.floor(elapsedMs / 1000);
        const minutes = Math.floor(totalSeconds / 60);
        const seconds = totalSeconds % 60;
        elapsedLabel.textContent = `${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
      };

      const appendStageLog = (stage, text) => {
        if (lastStageLogged === stage) {
          return;
        }

        lastStageLogged = stage;
        output.textContent += `\n[stage] ${text}\n`;
      };

      const updateStageProgress = (result) => {
        const stage = typeof result.stage === 'string' ? result.stage : '';

        if (stage === 'starting') {
          setStatus('Launching yt-dlp...', 'idle');
          appendStageLog('starting', 'Launching yt-dlp');
          setProgressIfHigher(3);
          return;
        }

        if (stage === 'downloading') {
          setStatus('Downloading...', 'idle');
          appendStageLog('downloading', 'Downloading media segments');
          if (typeof result.progress === 'number') {
            // Download stage occupies 10..85% of total pipeline
            const staged = 10 + (Math.max(0, Math.min(100, result.progress)) * 0.75);
            setProgress(staged);
          } else {
            setProgressIfHigher(15);
          }
          return;
        }

        if (stage === 'starting-ffmpeg') {
          setStatus('Starting ffmpeg...', 'idle');
          appendStageLog('starting-ffmpeg', 'Starting ffmpeg post-processing');
          setProgressIfHigher(88);
          return;
        }

        if (stage === 'converting') {
          setStatus('Converting...', 'idle');
          appendStageLog('converting', 'Converting output format with ffmpeg');
          if (typeof result.progress === 'number') {
            // Convert stage occupies 88..99.5% of total pipeline
            const staged = 88 + (Math.max(0, Math.min(100, result.progress)) * 0.115);
            setProgress(staged);
          } else {
            setProgressIfHigher(95);
          }

          if (!hasConvertingLogNotice) {
            appendLog('\n[app] Converting...\n');
            hasConvertingLogNotice = true;
          }
        }
      };

      const syncDetailsVisibility = () => {
        const showDetails = hasDownloadDetails && isDetailsExpanded;
        progressWrap.classList.toggle('hidden', !showDetails);
        output.classList.toggle('hidden', !showDetails);

        detailsActions.classList.toggle('hidden', !hasDownloadDetails);
        toggleDetailsButton.disabled = !hasDownloadDetails;
        toggleDetailsButton.textContent = isDetailsExpanded
          ? 'Hide progress and log'
          : 'Show progress and log';
      };

      const setBusy = (isBusy) => {
        downloadButton.disabled = isBusy || !runtimeReady;
        videoProfileSelect.disabled = isBusy;
        qualitySelect.disabled = isBusy;
        urlInput.readOnly = isBusy;
        spinner.classList.toggle('active', isBusy);
        stopButton.classList.toggle('hidden', !isBusy);
        stopButton.disabled = !isBusy || isStoppingDownload;
        openFolderButton.disabled = isBusy || !hasSuccessfulDownload;
        openFolderButton.classList.toggle('hidden', !hasSuccessfulDownload);
      };

      const stopActiveDownload = async () => {
        if (activeJobId === null || isStoppingDownload) {
          return;
        }

        isStoppingDownload = true;
        stopButton.disabled = true;

        try {
          const stopDownloadBinding = await waitForBinding('stopDownload');
          const result = await stopDownloadBinding(activeJobId);

          setStatus(result.message, result.success ? 'ok' : 'error');
          if (result.success) {
            markProgressStopped();
          }

          stopPolling();
          activeJobId = null;
          setBusy(false);
        } catch (error) {
          const message = toErrorMessage(error);
          setStatus(`Stop error: ${message}`, 'error');
        } finally {
          isStoppingDownload = false;
          stopButton.disabled = activeJobId === null;
        }
      };

      const updateFormatControlsVisibility = () => {
        const hasUrl = urlInput.value.trim().length > 0;
        formatControls.classList.toggle('hidden', !hasUrl);
      };

      const toErrorMessage = (error) => String(error);

      const waitForBinding = async (name, timeoutMs = 6000) => {
        const startedAt = Date.now();

        while (typeof window[name] !== 'function') {
          if (Date.now() - startedAt >= timeoutMs) {
            throw new Error(`Binding "${name}" is unavailable.`);
          }

          await new Promise((resolve) => setTimeout(resolve, 50));
        }

        return window[name];
      };

      const requestCloseApplication = async () => {
        if (isClosingApplication) {
          return;
        }

        isClosingApplication = true;
        try {
          const closeApplicationBinding = await waitForBinding('closeApplication');
          await closeApplicationBinding();
        } catch (error) {
          const message = toErrorMessage(error);
          setStatus(`Cannot close app: ${message}`, 'error');
          isClosingApplication = false;
        }
      };

      const flushUiFrame = () => new Promise((resolve) => {
        requestAnimationFrame(() => {
          requestAnimationFrame(() => resolve());
        });
      });

      const selectDownloadDirectory = async () => {
        try {
          const selectDownloadDirectoryBinding = await waitForBinding('selectDownloadDirectory');
          const result = await selectDownloadDirectoryBinding();
          if (result.success && result.directory) {
            selectedDownloadDirectory = result.directory;
            setStatus(`Will download to: ${result.directory}`, 'ok');
            return true;
          } else {
            setStatus(result.message || 'Folder selection cancelled.', 'error');
            return false;
          }
        } catch (error) {
          const message = toErrorMessage(error);
          setStatus(`Folder selection error: ${message}`, 'error');
          return false;
        }
      };

      const stopPolling = () => {
        if (pollTimer !== null) {
          clearInterval(pollTimer);
          pollTimer = null;
        }
      };

      const appendLog = (chunk) => {
        if (chunk) {
          output.textContent += chunk;
        }
      };

      const applyRuntimeCheck = (result) => {
        runtimeReady = result.success === true;
        installCommand = typeof result.installCommand === 'string' ? result.installCommand : '';

        if (runtimeReady) {
          dependencyWarning.classList.add('hidden');
          dependencyInstallCommand.textContent = '';
          dependencyInstallCommand.classList.add('hidden');
          openInstallTerminalButton.disabled = true;
          setStatus('', 'idle');
          setBusy(false);
          return;
        }

        const fallbackMessage = Array.isArray(result.missing)
          ? `Missing runtime tools: ${result.missing.join(', ')}`
          : 'Runtime dependencies are unavailable.';
        const baseMessage = typeof result.message === 'string' && result.message.trim().length > 0
          ? result.message
          : fallbackMessage;
        dependencyWarningText.textContent = `${baseMessage}. Please install/reinstall them and restart the app.`;
        if (installCommand.length > 0) {
          dependencyInstallCommand.textContent = installCommand;
          dependencyInstallCommand.classList.remove('hidden');
        } else {
          dependencyInstallCommand.textContent = '';
          dependencyInstallCommand.classList.add('hidden');
        }
        dependencyWarning.classList.remove('hidden');
        openInstallTerminalButton.disabled = installCommand.length === 0;
        setStatus(result.message || 'Missing runtime tools.', 'error');
        setBusy(false);
      };

      const runRuntimeCheck = async () => {
        try {
          const checkRuntimeDependenciesBinding = await waitForBinding('checkRuntimeDependencies');
          const result = await checkRuntimeDependenciesBinding();
          applyRuntimeCheck(result);
        } catch (error) {
          const message = toErrorMessage(error);
          runtimeReady = false;
          dependencyWarningText.textContent = 'Cannot verify runtime dependencies.';
          dependencyWarning.classList.remove('hidden');
          openInstallTerminalButton.disabled = true;
          setStatus(`Dependency check error: ${message}`, 'error');
          setBusy(false);
        }
      };

      const selectedProfile = () => {
        const selectedId = videoProfileSelect.value;
        return profileCache.find((profile) => profile.id === selectedId) || profileCache[0];
      };

      const selectedFormatId = () => {
        const index = qualitySelect.selectedIndex;
        const hasSelection = index >= 0 && index < qualitySelect.options.length;
        const value = hasSelection ? qualitySelect.options[index].value : '';

        return value && value.length > 0 ? value : 'preset:mp4';
      };

      const renderProfiles = () => {
        videoProfileSelect.innerHTML = '';

        profileCache.forEach((profile, index) => {
          const option = document.createElement('option');
          option.value = profile.id;
          option.textContent = profile.label;
          if (index === 0) {
            option.selected = true;
          }

          videoProfileSelect.appendChild(option);
        });

        renderQualities();
      };

      const renderQualities = () => {
        const profile = selectedProfile();
        const qualities = profile.qualities;

        qualitySelect.innerHTML = '';

        qualities.forEach((quality, index) => {
          const option = document.createElement('option');
          option.value = quality.formatId;
          option.textContent = quality.label;
          if (index === 0) {
            option.selected = true;
          }

          qualitySelect.appendChild(option);
        });

        if (qualities.length === 0) {
          const option = document.createElement('option');
          option.value = 'preset:mp4';
          option.textContent = 'Fallback to MP4 auto';
          option.selected = true;
          qualitySelect.appendChild(option);
        }
      };

      const poll = async () => {
        if (activeJobId === null) {
          return;
        }

        try {
          const pollDownloadBinding = await waitForBinding('pollDownload');
          const result = await pollDownloadBinding(activeJobId, activeOffset);

          if (!result.success) {
            setStatus(result.message, 'error');
            stopPolling();
            setBusy(false);
            activeJobId = null;
            return;
          }

          updateElapsedLabel();
          appendLog(result.outputChunk);
          activeOffset = result.offset;

          updateStageProgress(result);

          if (result.done) {
            setStatus(result.message, result.isSuccess ? 'ok' : 'error');
            appendStageLog(result.isSuccess ? 'completed' : 'failed', result.isSuccess ? 'Completed successfully' : 'Failed');
            if (result.isSuccess) {
              setProgress(100);
              hasSuccessfulDownload = true;
            }

            stopPolling();
            setBusy(false);
            activeJobId = null;
            isStoppingDownload = false;
          }
        } catch (error) {
          const message = toErrorMessage(error);
          setStatus(`Polling error: ${message}`, 'error');
          stopPolling();
          setBusy(false);
          activeJobId = null;
          isStoppingDownload = false;
        }
      };

      videoProfileSelect.addEventListener('change', renderQualities);

      urlInput.addEventListener('input', () => {
        updateFormatControlsVisibility();
      });

      chooseFolderButton.addEventListener('click', async () => {
        await selectDownloadDirectory();
      });

      openFolderButton.addEventListener('click', async () => {
        try {
          const openDownloadsFolderBinding = await waitForBinding('openDownloadsFolder');
          const result = await openDownloadsFolderBinding(selectedDownloadDirectory || '');
          setStatus(result.message, result.success ? 'ok' : 'error');
        } catch (error) {
          const message = toErrorMessage(error);
          setStatus(`Open folder error: ${message}`, 'error');
        }
      });

      stopButton.addEventListener('click', async () => {
        await stopActiveDownload();
      });

      form.addEventListener('submit', async (event) => {
        event.preventDefault();

        if (!runtimeReady) {
          setStatus('Install required runtime tools first.', 'error');
          return;
        }

        if (!selectedDownloadDirectory) {
          const dirSelected = await selectDownloadDirectory();
          if (!dirSelected) {
            return;
          }
        }

        output.textContent = '';
        lastStageLogged = '';
        downloadStartedAt = Date.now();
        updateElapsedLabel();
        setProgress(0);
        progressValue.classList.remove('stopped');
        hasSuccessfulDownload = false;
        hasConvertingLogNotice = false;
        openFolderButton.disabled = true;
        openFolderButton.classList.add('hidden');

        const url = urlInput.value.trim();
        if (url.length === 0) {
          setStatus('Please paste URL first.', 'error');
          return;
        }

        hasDownloadDetails = true;
        isDetailsExpanded = true;
        syncDetailsVisibility();

        setBusy(true);
        setStatus('Launching yt-dlp...', 'idle');
        appendStageLog('starting', 'Launching yt-dlp');
        setProgress(3);

        // Stage: loading manifest and preparing format selection.
        setStatus('Loading manifest...', 'idle');
        appendStageLog('manifest', 'Loading video manifest and available streams');
        setProgressIfHigher(8);

        // Let UI repaint and show stage status/spinner before backend call
        await flushUiFrame();

        try {
          const startDownloadBinding = await waitForBinding('startDownload');
          const result = await startDownloadBinding(url, selectedFormatId(), selectedDownloadDirectory || '');

          if (!result.success || !result.jobId) {
            setStatus(result.message, 'error');
            setBusy(false);
            return;
          }

          setStatus('Downloading...', 'idle');
          setProgressIfHigher(10);

          activeJobId = result.jobId;
          activeOffset = result.offset;
          pollTimer = setInterval(poll, 400);
          await poll();
        } catch (error) {
          const message = toErrorMessage(error);
          setStatus(`Binding error: ${message}`, 'error');
          setBusy(false);
        }
      });

      toggleDetailsButton.addEventListener('click', () => {
        if (!hasDownloadDetails) {
          return;
        }

        isDetailsExpanded = !isDetailsExpanded;
        syncDetailsVisibility();
      });

      openInstallTerminalButton.addEventListener('click', async () => {
        if (installCommand.length === 0) {
          setStatus('Install command is unavailable.', 'error');
          return;
        }

        try {
          const openInstallCommandInTerminalBinding = await waitForBinding('openInstallCommandInTerminal');
          const result = await openInstallCommandInTerminalBinding(installCommand);
          setStatus(result.message, result.success ? 'ok' : 'error');
        } catch (error) {
          const message = toErrorMessage(error);
          setStatus(`Cannot open terminal: ${message}`, 'error');
        }
      });

      document.addEventListener('keydown', (event) => {
        const key = String(event.key || '').toLowerCase();
        const hasCloseModifier = event.ctrlKey || event.metaKey;
        const isCloseShortcut = key === 'w' || key === 'q';

        if (!hasCloseModifier || !isCloseShortcut) {
          return;
        }

        event.preventDefault();
        requestCloseApplication();
      });

      renderProfiles();
      updateFormatControlsVisibility();
      syncDetailsVisibility();
      setBusy(false);
      runRuntimeCheck();
  </script>
</body>
</html>
HTML;

$app->run();

