    .progress-value.stopped { animation: none; background: linear-gradient(90deg, #ef4444, #dc2626); }
    pre { margin-top: 12px; white-space: pre-wrap; background: #0b1220; border: 1px solid #334155; border-radius: 8px; padding: 12px; min-height: 180px; max-height: 320px; overflow: auto; }
    code { background: #1f2937; padding: 2px 6px; border-radius: 6px; }
